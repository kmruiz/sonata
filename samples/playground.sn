requires std.log

entity class Ping() {
    let ping(ponger: Pong) = {
        ponger.pong()
    }
}

entity class Pong() {
    let logger = defaultLogger('Pong', ConsoleLogAppender())

    let pong() = {
        logger.error('Pong!', true)
    }
}

let pinger = Ping()
let ponger = Pong()

pinger.ping(ponger)

exit()

